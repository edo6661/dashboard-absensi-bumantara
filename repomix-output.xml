              <button
                onClick={onClose}
                className="p-2.5 text-zinc-400 hover:text-zinc-900 hover:bg-zinc-100 rounded-xl transition-all cursor-pointer bg-zinc-50"
              >
                <X size={20} strokeWidth={2} />
